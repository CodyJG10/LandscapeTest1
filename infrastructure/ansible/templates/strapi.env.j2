# Site identity
SITE_NAME={{ site_name }}
COMPOSE_PROJECT_NAME={{ site_name }}

# Strapi application
HOST={{ strapi_host | default('0.0.0.0') }}
PORT={{ strapi_port | default('1337') }}
APP_KEYS="{{ strapi_app_keys }}"
API_TOKEN_SALT={{ strapi_api_token_salt }}
ADMIN_JWT_SECRET={{ strapi_admin_jwt_secret }}
TRANSFER_TOKEN_SALT={{ strapi_transfer_token_salt }}
JWT_SECRET={{ strapi_jwt_secret }}
ENCRYPTION_KEY={{ strapi_encryption_key }}

# Database — DATABASE_HOST must match the Compose service name
DATABASE_CLIENT={{ db_client | default('postgres') }}
DATABASE_HOST=strapiDB
DATABASE_NAME={{ db_name }}
DATABASE_USERNAME={{ db_username }}
DATABASE_PASSWORD={{ db_password }}
DATABASE_PORT={{ db_port | default('5432') }}

NODE_ENV={{ node_env | default('production') }}
