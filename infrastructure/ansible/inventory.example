[strapi_servers]
my-vps ansible_host=<VPS_IP> ansible_user=root ansible_ssh_private_key_file=~/.ssh/id_rsa

# To use password auth instead of a key:
# my-vps ansible_host=<VPS_IP> ansible_user=root ansible_password=<password>

# Multiple sites can share the same VPS — site isolation is handled by site_name:
# my-vps2 ansible_host=<VPS_IP_2> ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/id_rsa ansible_become=true
