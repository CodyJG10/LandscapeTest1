---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>My Site</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: system-ui, sans-serif;
        background: #f5f5f5;
        color: #222;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      header {
        background: #1a1a2e;
        color: #fff;
        padding: 1.25rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      header h1 { font-size: 1.4rem; letter-spacing: 0.05em; }

      nav a {
        color: #ccc;
        text-decoration: none;
        margin-left: 1.5rem;
        font-size: 0.95rem;
      }

      nav a:hover { color: #fff; }

      main {
        flex: 1;
        max-width: 860px;
        margin: 3rem auto;
        padding: 0 1.5rem;
      }

      .hero {
        text-align: center;
        padding: 3rem 1rem;
      }

      .hero h2 {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        color: #1a1a2e;
      }

      .hero p {
        font-size: 1.1rem;
        color: #555;
        max-width: 520px;
        margin: 0 auto 2rem;
        line-height: 1.6;
      }

      .btn {
        display: inline-block;
        background: #1a1a2e;
        color: #fff;
        padding: 0.75rem 2rem;
        border-radius: 6px;
        text-decoration: none;
        font-size: 1rem;
        transition: background 0.2s;
      }

      .btn:hover { background: #2e2e5e; }

      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.5rem;
        margin-top: 3rem;
      }

      .card {
        background: #fff;
        border-radius: 10px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.07);
      }

      .card h3 { margin-bottom: 0.5rem; color: #1a1a2e; }
      .card p { color: #666; font-size: 0.95rem; line-height: 1.5; }

      footer {
        text-align: center;
        padding: 1.5rem;
        font-size: 0.85rem;
        color: #999;
        border-top: 1px solid #e0e0e0;
        background: #fff;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>My Site</h1>
      <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Contact</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <h2>Welcome to My Site</h2>
        <p>This is a simple one-page site built with Astro. Replace this content with whatever you need.</p>
        <a href="#" class="btn">Get Started</a>
      </section>

      <section class="cards">
        <div class="card">
          <h3>Feature One</h3>
          <p>Describe your first feature or highlight here. Keep it short and clear.</p>
        </div>
        <div class="card">
          <h3>Feature Two</h3>
          <p>Describe your second feature or highlight here. Keep it short and clear.</p>
        </div>
        <div class="card">
          <h3>Feature Three</h3>
          <p>Describe your third feature or highlight here. Keep it short and clear.</p>
        </div>
      </section>
    </main>

    <footer>
      &copy; {new Date().getFullYear()} My Site. All rights reserved.
    </footer>
  </body>
</html>
